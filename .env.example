# Local development environment template.
# Copy to `.env.local` (gitignored) and fill in real values.
#
# DO NOT add real secrets to this file. This is committed to source
# control and serves as documentation of which env vars exist.

# ─── Agent tools ────────────────────────────────────────────────────
# Live web search backend (web-search.ts). When unset, the tool falls
# back to DuckDuckGo HTML scrape (no key, lower quality, rate-limited).
# Get a key at https://api.search.brave.com/app/keys (1k free queries/mo).
BRAVE_SEARCH_API_KEY=

# Optional: self-hosted SearXNG instance URL (fallback before DDG).
# Example: https://searx.your-homelab.local
SEARXNG_URL=

# Optional: Etherscan API key for higher-rate ETH transaction polling
# in the license-payment poller (license/payments.ts).
ETHERSCAN_API_KEY=

# ─── License / sync ─────────────────────────────────────────────────
# Required in production (api.crimecode.cc) — HMAC secret for signing
# license tokens + auth session JWTs.
LICENSE_HMAC_SECRET=

# Telegram bot token + admin user IDs (comma-separated chat ids).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_IDS=
OPENCODE_ADMIN_CHAT_ID=

# Crypto wallets (license/wallets.ts).
BTC_WALLET_ADDRESS=
LTC_WALLET_ADDRESS=
ETH_WALLET_ADDRESS=

# ─── Sentry / observability ─────────────────────────────────────────
SENTRY_DSN=

# ─── Cloud sync (CrimeCode-Relay) ───────────────────────────────────
CRIMECODE_RELAY_URL=
CRIMECODE_RELAY_ADMIN_TOKEN=
