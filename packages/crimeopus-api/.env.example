# CrimeOpus API — configurazione runtime.
# Copia in `.env` (NON committarlo) e personalizza.

# ── Networking ───────────────────────────────────────────────────────
API_PORT=8787
PORT=8787
BIND=0.0.0.0
OLLAMA_URL=http://127.0.0.1:11434

# Whisper bridging — punta a faster-whisper-server / whisper.cpp / localai
WHISPER_URL=http://127.0.0.1:9000
# WHISPER_API_KEY=xxx                 # opzionale, Bearer per upstream
WHISPER_MODEL_DEFAULT=whisper-1

# ── Auth ─────────────────────────────────────────────────────────────
# Static API keys (sincronizzate nel DB al boot, gestibili da /admin).
# Forma JSON estesa (consigliata):
#   API_KEYS={"sk-abc":{"label":"alice","rpm":120,"tokenQuota":5000000,"requestQuota":50000,"scopes":["chat","embed"]}}
# Forma JSON breve:
#   API_KEYS={"sk-abc":"alice","sk-def":"bob"}
# Forma CSV (solo keys, label=primi 12 char, no quota):
#   API_KEYS=sk-key1,sk-key2
API_KEYS={"sk-prod-CHANGE-ME":"prod","sk-dev-CHANGE-ME":"dev"}

# JWT multi-tenant (HS256). Lascia vuoto per disabilitare.
# Genera: openssl rand -hex 32
# JWT_SECRET=

# JWT con RS256 (alternativa a HS256): incolla la chiave pubblica PEM
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"

# ── Admin dashboard ──────────────────────────────────────────────────
# Lascia vuoto per disabilitare /admin (consigliato in dev).
# In prod: usa una password forte E proteggi con firewall/Caddy basic-auth.
# ADMIN_PASSWORD=

# ── Rate limit globale (override per chiave nel DB / via JSON env) ───
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Storage paths ───────────────────────────────────────────────────
LOG_DB=./usage.db
CATALOG_PATH=./catalog.json

# ── Dev only ────────────────────────────────────────────────────────
# ALLOW_ANON=1   # bypass auth, NEVER in prod
