# CrimeOpus API — configurazione runtime.
# Copia in `.env` (NON committarlo) e personalizza.

# Porta su cui il container espone l'API (sull'host).
API_PORT=8787

# Chiavi API.
# Forma JSON (consigliata): mappa key → label, opzionalmente con rpm override
#   API_KEYS={"sk-prod-abc":{"label":"alice","rpm":120}, "sk-dev":"local"}
# Forma CSV: solo le chiavi, label = primi 12 char
#   API_KEYS=sk-key1,sk-key2,sk-key3
API_KEYS={"sk-prod-CHANGE-ME":"prod","sk-dev-CHANGE-ME":"dev"}

# Rate limiting per chiave (token bucket)
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# CORS — "*" per dev, lista esplicita per prod
CORS_ORIGINS=*
