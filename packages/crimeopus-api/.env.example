# CrimeOpus API — configurazione runtime.
# Copia in `.env` (NON committarlo) e personalizza.

# ── Networking ───────────────────────────────────────────────────────
API_PORT=8787
PORT=8787
BIND=0.0.0.0

# ── UPSTREAM PROVIDERS ───────────────────────────────────────────────
# Pool di provider OpenAI-compatible. Il gateway sceglie il primo
# healthy con slot libero per ogni richiesta (vedi catalog.json per le
# routes per-modello).
#
# COSA HOSTA TU: niente. Il compute gira sui cloud provider qui sotto;
# tu paghi solo i token che gli utenti consumano e fatturi loro a margine.
#
# Esempi pronti — copia, ottieni le API key da ciascun provider, salva
# come una sola riga JSON. Il `kind` può essere "openai" (default) o
# "ollama" (solo per dev locale).
#
#   Together AI:        https://api.together.xyz/v1
#   Fireworks AI:       https://api.fireworks.ai/inference/v1
#   OpenRouter:         https://openrouter.ai/api/v1
#   Groq (super fast):  https://api.groq.com/openai/v1
#   Anyscale:           https://api.endpoints.anyscale.com/v1
#   DeepInfra:          https://api.deepinfra.com/v1/openai
#   RunPod Serverless:  https://api.runpod.ai/v2/<endpoint-id>/openai/v1
#   Modal:              https://<your-app>.modal.run/v1
#   Local Ollama (dev): http://127.0.0.1:11434  (kind: "ollama")
#
# Schema:
#   { "id":"...", "kind":"openai|ollama", "url":"...", "apiKey":"...",
#     "weight": 1, "maxInflight": 8 }
#
# Production-ready esempio (no PC locale):
UPSTREAM_PROVIDERS=[{"id":"together","kind":"openai","url":"https://api.together.xyz/v1","apiKey":"YOUR_TOGETHER_KEY","weight":3,"maxInflight":10},{"id":"openrouter","kind":"openai","url":"https://openrouter.ai/api/v1","apiKey":"YOUR_OPENROUTER_KEY","weight":1,"maxInflight":5}]

# Per dev locale (sviluppo, no costi cloud) decomenta e usa solo questo:
#UPSTREAM_PROVIDERS=[{"id":"local-ollama","kind":"ollama","url":"http://127.0.0.1:11434","weight":1,"maxInflight":2}]

# ── Concorrenza globale ──────────────────────────────────────────────
# MAX_CONCURRENCY si applica per-provider (override via maxInflight nello
# schema sopra). PER_KEY_CONCURRENCY limita un singolo cliente a N
# richieste in volo: protegge da un cliente con script paralleli che
# saturerebbe il budget cloud.
MAX_CONCURRENCY=4
PER_KEY_CONCURRENCY=2
QUEUE_MAX=50
QUEUE_TIMEOUT_MS=30000

# ── Whisper bridging (STT) ───────────────────────────────────────────
# Anche qui meglio cloud: faster-whisper-server self-host costa ~$0.30/h GPU,
# Groq Whisper costa ~$0.04/h di audio. Lascia vuoto se non usi STT.
WHISPER_URL=https://api.groq.com/openai
WHISPER_API_KEY=YOUR_GROQ_KEY
WHISPER_MODEL_DEFAULT=whisper-large-v3-turbo

# ── Auth ─────────────────────────────────────────────────────────────
# Static API keys (sincronizzate nel DB al boot, gestibili da /admin).
# Forma JSON estesa (consigliata):
#   API_KEYS={"sk-abc":{"label":"alice","rpm":120,"tokenQuota":5000000,"requestQuota":50000,"scopes":["chat","embed"]}}
# Forma JSON breve:
#   API_KEYS={"sk-abc":"alice","sk-def":"bob"}
# Forma CSV (solo keys, label=primi 12 char, no quota):
#   API_KEYS=sk-key1,sk-key2
API_KEYS={"sk-prod-CHANGE-ME":"prod","sk-dev-CHANGE-ME":"dev"}

# JWT multi-tenant (HS256). Lascia vuoto per disabilitare.
# Genera: openssl rand -hex 32
# JWT_SECRET=

# JWT con RS256 (alternativa a HS256): incolla la chiave pubblica PEM
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"

# ── Admin dashboard ──────────────────────────────────────────────────
# Lascia vuoto per disabilitare /admin (consigliato in dev).
# In prod: usa una password forte E proteggi con firewall/Caddy basic-auth.
# ADMIN_PASSWORD=

# ── Rate limit globale (override per chiave nel DB / via JSON env) ───
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ── CORS ────────────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Storage paths ───────────────────────────────────────────────────
LOG_DB=./usage.db
CATALOG_PATH=./catalog.json

# ── Dev only ────────────────────────────────────────────────────────
# ALLOW_ANON=1   # bypass auth, NEVER in prod
