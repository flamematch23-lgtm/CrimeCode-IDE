{
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "lib": ["ESNext", "DOM"],
    "types": ["bun"]
  },
  "include": ["src/**/*.ts"]
}
